{
  "name": "@hauska-engine/retrieval-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Retrieval API HTTP service (Stream 1C). Consumed by hauska-mcp-server Stream 2A. Locked contract is the Sync-3 deliverable.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@hauska-engine/atom-contract-pin": "workspace:*",
    "@hauska-engine/retrieval": "workspace:*",
    "@hauska-engine/storage": "workspace:*",
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@hauska-engine/corpus": "workspace:*",
    "tsx": "^4.19.2",
    "typescript": "~5.7.2",
    "vitest": "^2.1.8"
  }
}
