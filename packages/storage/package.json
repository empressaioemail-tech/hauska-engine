{
  "name": "@hauska-engine/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Atom storage substrate per ADR-010. IPFS pinning + Postgres index + in-process hot cache + atom-link graph + vector embeddings (pgvector).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@hauska-engine/atom-contract-pin": "workspace:*",
    "@hauska-engine/atoms": "workspace:*",
    "@hauska-engine/identity": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "typescript": "~5.7.2",
    "vitest": "^2.1.8"
  }
}
